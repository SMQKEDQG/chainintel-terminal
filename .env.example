# ============================================================================
# ChainIntel Terminal — Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local or any file containing real secrets.
#
# In Vercel, all variables marked [SENSITIVE] below MUST be added with the
# "Sensitive" toggle enabled so they are encrypted at rest and unreadable
# via the API after creation.
# ============================================================================

# --- Supabase -----------------------------------------------------------
# Project URL (public — safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Anon/public key (public — safe for client-side, used for unauthenticated requests)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Service role key — full database access, bypasses RLS [SENSITIVE]
# Only used server-side in API routes. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# --- Stripe --------------------------------------------------------------
# Secret key for server-side Stripe API calls [SENSITIVE]
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...

# Webhook signing secret for verifying Stripe event signatures [SENSITIVE]
# Get from: https://dashboard.stripe.com/webhooks → select endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Resend (Email) ------------------------------------------------------
# API key for transactional emails [SENSITIVE]
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# --- CoinMarketCap -------------------------------------------------------
# API key for cryptocurrency market data [SENSITIVE]
# Get from: https://pro.coinmarketcap.com/account
CMC_API_KEY=your-cmc-api-key

# --- Admin ----------------------------------------------------------------
# Secret token for admin API routes [SENSITIVE]
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ADMIN_SECRET=your-admin-secret
